{
  "name": "catcast-sender",
  "version": "1.0.0",
  "description": "Application for screen casting to LG TV",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "dev": "electron . --debug"
  },
  "keywords": [
    "screen-cast",
    "catcast",
    "streaming"
  ],
  "author": "Bruno",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^23.6.0"
  },
  "dependencies": {
    "electron-log": "^5.0.1",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "express": "^4.18.2",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "node-media-server": "^4.2.4",
    "qrcode": "^1.5.4",
    "sharp": "^0.33.0",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "systeminformation": "^5.18.1",
    "ws": "^8.14.2"
  },
  "build": {
    "appId": "com.bruno.catcast.sender",
    "productName": "CatCast Sender",
    "directories": {
      "output": "dist"
    },
    "asarUnpack": [
      "wasapi_capture.exe",
      "node_modules/ffmpeg-static/ffmpeg.exe"
    ],
    "files": [
      "**/*",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/node_modules/*.d.ts",
      "!**/*.iml",
      "!{.eslintrc.json,.gitignore,.travis.yml,README.md}"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icons/icon.ico",
      "publisherName": "Bruno"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icons/icon.icns",
      "category": "public.app-category.video"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icons/icon.png",
      "category": "Video"
    }
  }
}
